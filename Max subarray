class Solution {
    public int maxSubArray(int[] arr) {
        int max = Integer.MIN_VALUE;
        int i = 0;
        int sum = 0;
        while(i<arr.length){
            sum += arr[i];
            max = Math.max(sum,max);
            if(sum<0){
                sum = 0;
            }
            i++;
        }
        System.out.println(max);
        return max;
    }
}
